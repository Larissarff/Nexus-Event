@page "/register"
@rendermode InteractiveServer

@using backend.Entities
@using backend.Services
@inject UsuarioService UsuarioService

<div class="auth-container"> 
    <h3>Cadastro</h3>

    <div class="form-group">
        <label>Nome</label>
        <input class="form-control-custom"
               type="text"
               placeholder="Digite seu nome"
               @bind="usuario.Nome" />
    </div>

    <div class="form-group">
        <label>E-mail</label>
        <input class="form-control-custom"
               type="email"
               placeholder="Digite seu e-mail"
               @bind="usuario.Email" />
    </div>

    <div class="form-group">
        <label>CPF</label>
        <input class="form-control-custom"
               type="text"
               placeholder="Digite seu CPF"
               @bind="usuario.Cpf" />
    </div>

    <div class="form-group">
        <label>Senha</label>
        <input class="form-control-custom"
               type="password"
               placeholder="Crie uma senha"
               @bind="usuario.SenhaHash" />
    </div>

    <button type="button" class="auth-main-button" @onclick="Cadastrar">
    Cadastrar
</button>

    @if (!string.IsNullOrEmpty(erro))
    {
        <p style="color:red">@erro</p>
    }

    @if (!string.IsNullOrEmpty(sucesso))
    {
        <p style="color:green">@sucesso</p>
    }
</div>
@code {
    // Simplifique a inicialização. O Blazor preenche os dados via @bind.
    private UsuarioEntity usuario = new();

    private string? erro;
    private string? sucesso;

   private async Task Cadastrar()
{
    erro = null;
    sucesso = null;

    Console.WriteLine($"Tentando cadastrar: {usuario.Nome}, {usuario.Email}");

    try
    {
        if (string.IsNullOrEmpty(usuario.Nome) || string.IsNullOrEmpty(usuario.Email))
        {
            erro = "Por favor, preencha os campos obrigatórios.";
            return;
        }

        await UsuarioService.CriarUsuarioAsync(usuario);
        sucesso = "Usuário cadastrado com sucesso!";

        // Aguarda o próximo ciclo de render antes de limpar
        await Task.Delay(1);
        usuario = new();
    }
    catch (Exception ex)
    {
        erro = "Erro ao cadastrar: " + ex.Message;
    }
}
}